# 测试环境示例配置（不要直接提交真实 token）
# 用法：复制为 .env，然后填写真实值。

DISCORD_TOKEN=
CLIENT_ID=
# 命令注册目标服务器ID列表（逗号分隔），建议只填测试服
# 当前测试服务器：1397932215089758219
GUILD_IDS=1397932215089758219

# SelfRole 测试辅助命令（会额外注册 /自助身份组申请-测试）
SELF_ROLE_ENABLE_TEST_COMMANDS=true

# 启动时强制同步命令：若任意目标服务器注册失败则中止启动（推荐测试环境开启）
STRICT_COMMAND_SYNC=true

# 清空该应用的全局命令（Global Commands），避免之前其它测试项目遗留的全局命令在测试服里出现。
# 注意：全局命令删除可能存在缓存延迟（通常可达 ~1 小时）。
CLEAR_GLOBAL_COMMANDS=true


# 可选：异常报告时要 @ 的管理员身份组（不填则不 ping）
SELF_ROLE_ALERT_MENTION_ROLE_ID=


# ===== SelfRole 成员缓存/现任统计（可选） =====
# 若你重启 bot 后发现面板“现任人数=0”，基本就是成员缓存未加载。
# 测试环境建议保持 auto；如测试服很小也可设 always。
SELF_ROLE_MEMBER_FETCH_MODE=auto
SELF_ROLE_MEMBER_FETCH_MAX_GUILD_SIZE=5000
SELF_ROLE_MEMBER_FETCH_TIMEOUT_MS=30000
SELF_ROLE_MEMBER_FETCH_MAX_AGE_MINUTES=10
SELF_ROLE_MEMBER_FETCH_COVERAGE_THRESHOLD=0.8

# 可选：REST 请求超时（毫秒）。用于避免网络异常时请求长时间挂起导致交互无响应。
DISCORD_REST_TIMEOUT_MS=15000

# 可选：每 N 分钟输出一次健康日志（0=关闭）。测试环境建议先开 1，便于判断进程/连接是否仍存活。
HEALTH_LOG_INTERVAL_MINUTES=1

# 可选：发生 uncaughtException 时是否直接退出进程（建议配合守护进程使用）
FATAL_EXIT_ON_EXCEPTION=false

# 可选：交互调试日志（用于排查“命令无响应但控制台无日志”）
INTERACTION_DEBUG_LOG=false
